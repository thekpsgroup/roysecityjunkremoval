{
  "name": "roysecityjunkremoval",
  "version": "1.0.0",
  "description": "Royse City Junk Removal website - An I30 Builders Company",
  "private": true,
  "scripts": {
    "css:build": "cleancss -O2 assets/css/style.src.css -o assets/css/style.css",
    "css:watch": "cleancss -O2 assets/css/style.src.css -o assets/css/style.css --watch",
    "seo:audit": "node scripts/seo-audit.mjs",
    "seo:refresh": "node scripts/seo-audit.mjs --write-sitemap"
  },
  "dependencies": {
    "ioredis": "^5.4.1",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3"
  },
  "engines": {
    "node": ">=18"
  }
}
